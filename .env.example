# GitHub Configuration
# Replace 'paste_your_token_here' with your actual GitHub Personal Access Token
GITHUB_TOKEN=paste_your_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repository-name

# Server Configuration
PORT=3000

# Security
API_KEY=REPLACE_WITH_GENERATED_KEY_FROM_COMMAND_BELOW

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit the .env file to version control
#
# To generate a GitHub Personal Access Token:
# 1. Go to GitHub Settings > Developer settings > Personal access tokens > Tokens (classic)
# 2. Click "Generate new token (classic)"
# 3. Give it a descriptive name (e.g., "ICA Workflow Trigger")
# 4. Select scopes: 'repo' and 'workflow'
# 5. Click "Generate token" and copy the token immediately
# 6. Paste it as the GITHUB_TOKEN value above
#
# To generate a secure API key:
# Run this in your terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"